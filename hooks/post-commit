#!/usr/bin/env bash
# Auto-rebuild csmar-mcp container after every commit.
# Activate with: git config core.hooksPath hooks
set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [ ! -f .env ]; then
  echo "[post-commit] .env missing; skipping rebuild." >&2
  exit 0
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "[post-commit] docker not found on PATH; skipping rebuild." >&2
  exit 0
fi

echo "[post-commit] rebuilding csmar-mcp container..."
docker compose up -d --build
